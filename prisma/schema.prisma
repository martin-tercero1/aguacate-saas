// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma/client"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  expenses   Expense[]
  incomes    Income[]
  harvests   Harvest[]
  activities Activity[]
  
  @@map("users")
}

model Expense {
  id          String   @id @default(cuid())
  userId      String
  category    String   // insumos, mano_de_obra, mantenimiento, transporte, etc.
  description String?
  amount      Decimal  @db.Decimal(10, 2)
  date        DateTime
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@map("expenses")
}

model Income {
  id          String   @id @default(cuid())
  userId      String
  source      String   // venta_cosechas, otros
  description String?
  amount      Decimal  @db.Decimal(10, 2)
  date        DateTime
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@map("incomes")
}

model Harvest {
  id          String   @id @default(cuid())
  userId      String
  parcela     String
  cantidad    Decimal  @db.Decimal(10, 2)
  calidad     String?  // alta, media, baja
  fechaCosecha DateTime
  precioUnitario Decimal @db.Decimal(10, 2)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@map("harvests")
}

model Activity {
  id          String   @id @default(cuid())
  userId      String
  tipo        String   // siembra, abono, fumigacion, poda, riego
  parcela     String
  descripcion String?
  fecha       DateTime
  estado      String   @default("pendiente") // pendiente, completado, en_proceso
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@map("activities")
}
